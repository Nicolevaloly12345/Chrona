{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with gamification and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email" },
        "points": { "type": "integer", "description": "Total gamification points" },
        "savedLocations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" },
              "type": { "type": "string", "enum": ["home", "work", "other"] }
            }
          },
          "description": "Saved origin and destination addresses"
        },
        "preferredTransport": {
          "type": "string",
          "enum": ["car", "public_transport", "bicycle", "walking"],
          "description": "Preferred mode of transport"
        },
        "recurringSchedules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"] },
              "time": { "type": "string", "format": "time" },
              "origin": { "type": "string" },
              "destination": { "type": "string" }
            }
          },
          "description": "Recurring travel schedules"
        }
      },
      "required": ["uid", "points"]
    },
    "TrafficReport": {
      "title": "Traffic Report",
      "description": "Anonymous traffic contribution",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["accident", "roadworks", "hazard", "congestion"] },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "integer" },
        "userId": { "type": "string", "description": "UID of the contributor (optional for anonymity)" }
      },
      "required": ["type", "lat", "lng", "timestamp"]
    },
    "Reward": {
      "title": "Reward",
      "description": "Redeemable benefit",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "cost": { "type": "integer" }
      },
      "required": ["name", "cost"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/trafficReports/{reportId}": {
      "schema": "TrafficReport",
      "description": "Traffic reports"
    },
    "/rewards/{rewardId}": {
      "schema": "Reward",
      "description": "Available rewards"
    }
  }
}
